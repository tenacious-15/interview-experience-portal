# Server configuration
PORT=5000
NODE_ENV=development

# JWT Secrets (replace with long random strings in production)
JWT_SECRET=your_jwt_access_secret_key_123456789_abcdef
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_987654321_fedcba

# Database configuration (omit to run in Zero-Config Mock JSON DB Mode)
# MONGO_URI=mongodb://localhost:27017/interview-experience-portal

# Cloudinary configuration (omit to store avatars locally in /uploads)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Email configuration (omit to log verification/reset emails to server console)
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
# EMAIL_FROM=noreply@interviewexperience.com
